# ───────────────────────────────────────────
# RecruitIQ — Environment Configuration
# ───────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ───────────────────────────────────────────

# ── OpenRouter (LLM API) ──────────────────
QWEN_API_KEY=sk-or-v1-your-openrouter-api-key
QWEN_MODEL=qwen/qwen-2.5-7b-instruct
# QWEN_PREMIUM_MODEL=qwen/qwen3-next-80b-a3b-instruct  # used for executive hiring briefs

# ── Qdrant Cloud (Vector Database) ────────
QDRANT_URL=https://your-cluster-url.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=candidates

# ── Supabase (PostgreSQL + Storage) ───────
SUPABASE_URL=https://your-project.supabase.co
# IMPORTANT: Use the service_role key (NOT the anon/public key).
# The service_role key bypasses RLS and is required for server-side operations.
# Find it at: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Clerk (Authentication) ────────────────
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key

# ── Resend (Transactional Email) ───────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── Redis (Cache + Queue + Rate Limiting) ─
REDIS_URL=rediss://default:password@host.upstash.io:6379

# ── Server ────────────────────────────────
PORT=8080
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ── Optional ──────────────────────────────
# CORS_ORIGINS=https://your-production-domain.com
# EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
