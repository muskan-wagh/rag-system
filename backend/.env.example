# =============================================================================
# RecruitIQ Backend — Environment Variable Reference
# =============================================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For production (Render, Railway, etc.), set these via the dashboard:
#   Dashboard → your-service → Environment → add each variable
# =============================================================================

# ── LLM (OpenRouter) ──────────────────────────────────────────────────────────
# Required by: API + Worker
QWEN_API_KEY=sk-or-v1-your-key-here
QWEN_MODEL=qwen/qwen3-next-80b-a3b-instruct

# ── Qdrant (Vector Database) ──────────────────────────────────────────────────
# Required by: API + Worker
QDRANT_URL=https://your-cluster-url.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=candidates

# ── Supabase (PostgreSQL + Storage) ──────────────────────────────────────────
# Required by: API + Worker
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Redis (Upstash) ──────────────────────────────────────────────────────────
# Required by: API + Worker
# BullMQ queue + rate limiting + WebSocket pub/sub all depend on Redis.
REDIS_URL=rediss://default:password@your-redis.upstash.io:6379

# ── Auth ─────────────────────────────────────────────────────────────────────
# Required by: API
RECRUITER_PASSWORD=change-me-to-a-strong-password

# ── Server ───────────────────────────────────────────────────────────────────
# Optional — defaults shown
PORT=8080
NODE_ENV=development
CLIENT_URL=http://localhost:3000
CORS_ORIGINS=https://your-frontend.vercel.app
API_KEY=
