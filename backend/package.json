{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node start.js",
    "start:worker": "node start-worker.js",
    "start:all": "node start-all.js",
    "dev": "ts-node-dev --respawn --require tsconfig-paths/register src/server.ts",
    "dev:all": "ts-node-dev --respawn --require tsconfig-paths/register src/worker.ts & ts-node-dev --respawn --require tsconfig-paths/register src/server.ts & wait",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker": "ts-node-dev --respawn --require tsconfig-paths/register src/worker.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@clerk/backend": "^3.11.7",
    "@qdrant/js-client-rest": "^1.18.0",
    "@supabase/supabase-js": "^2.109.0",
    "@xenova/transformers": "^2.17.2",
    "bullmq": "^5.79.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "pdf-parse": "^2.4.5",
    "tsconfig-paths": "^4.2.0",
    "winston": "^3.19.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^25.9.3",
    "@types/ws": "^8.18.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
